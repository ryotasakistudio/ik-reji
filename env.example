# Supabase 設定
# Supabase ダッシュボード > Settings > API から取得する

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 使い方:
# 1. このファイルを .env にコピーする
#    cp .env.example .env
# 2. .env に実際の値を入力する
# 3. .env は .gitignore に追加して git 管理から外す
# 4. index.html の YOUR_SUPABASE_URL / YOUR_SUPABASE_ANON_KEY を置き換える
